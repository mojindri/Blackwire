{
  "log": { "loglevel": "warning" },
  "inbounds": [
    { "tag": "socks-in", "listen": "0.0.0.0", "port": 1080, "protocol": "socks", "settings": { "auth": "noauth" } }
  ],
  "outbounds": [
    {
      "tag": "blackwire-out",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "blackwire-server",
            "port": 8448,
            "users": [
              { "id": "00000000-0000-4000-8000-000000000001", "encryption": "none", "flow": "" }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "splithttp",
        "security": "tls",
        "tlsSettings": { "serverName": "blackwire.local", "allowInsecure": true },
        "splithttpSettings": {
          "path": "/split",
          "host": "blackwire.local",
          "mode": "stream-one",
          "uplinkHTTPMethod": "PUT"
        }
      }
    }
  ]
}
