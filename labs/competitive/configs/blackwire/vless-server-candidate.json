{
  "profile": "fast",
  "fast": {
    "strictProduction": false,
    "pool": "disabled",
    "splice": "adaptive",
    "relay": {
      "engine": "v2",
      "flush": "deferred",
      "initialBuffer": 16384,
      "maxBuffer": 262144
    }
  },
  "log": { "level": "warn" },
  "inbounds": [
    {
      "tag": "vless-in",
      "protocol": "vless",
      "listen": "127.0.0.1",
      "port": 10090,
      "settings": {
        "clients": [{ "id": "00000000-0000-4000-8000-000000000001" }]
      }
    }
  ],
  "outbounds": [
    { "tag": "freedom", "protocol": "freedom" }
  ]
}
